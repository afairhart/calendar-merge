# Copy this to .env for local testing (never commit .env)
# Paste your iCloud/Google/Outlook ICS subscription URLs here

CALENDAR_URL_1=https://p63-caldav.icloud.com/published/2/...
CALENDAR_URL_2=https://calendar.google.com/calendar/ical/.../basic.ics
CALENDAR_URL_3=https://...

# Optional: add a secret token so only people with your link can subscribe
# When set, the URL becomes: https://your-project.vercel.app/api/calendar?token=your-secret
SECRET_TOKEN=
